# Telegram Bot Token (получить у @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# AI Provider — любой OpenAI-совместимый API
# Примеры:
#   OpenAI:      AI_BASE_URL=https://api.openai.com/v1  AI_MODEL=gpt-4o-mini
#   OpenRouter:  AI_BASE_URL=https://openrouter.ai/api/v1  AI_MODEL=google/gemini-2.5-flash
#   Z.AI (GLM):  AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4  AI_MODEL=glm-4.7
#   Ollama:      AI_BASE_URL=http://localhost:11434/v1  AI_MODEL=llama3.2
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Путь к базе данных (опционально)
DB_PATH=data/vocal_tutor.db
